{
    "title": "Ctrl",
    "rules": [
        {
            "description": "Ctrl+H -> DeleteOrBackspace",
            "manipulators": [
                {
                    "type": "basic",
                    "from": { "key_code": "h", "modifiers": { "mandatory": [ "control" ], "optional" : [ "any" ] } },
                    "to": [ { "key_code": "delete_or_backspace" } ]
                }
            ]
        },
        {
            "description": "Ctrl+M -> ReturnOrEnter",
            "manipulators": [
                {
                    "type": "basic",
                    "from": { "key_code": "m", "modifiers": { "mandatory": [ "control" ], "optional" : [ "any" ] } },
                    "to": [ { "key_code": "return_or_enter" } ]
                }
            ]
        },
        {
            "description": "Ctrl+J -> かな",
            "manipulators": [
                {
                    "type": "basic",
                    "from": { "key_code": "j", "modifiers": { "mandatory": [ "control" ] } },
                    "to": [ { "key_code": "japanese_kana" } ]
                }
            ]
        },
        {
            "description": "Ctrl+J -> かな if english mode",
            "manipulators": [
                {
                    "type": "basic",
                    "conditions": [ { "input_sources": [ { "language": "en" } ], "type": "input_source_if" } ],
                    "from": { "key_code": "j", "modifiers": { "mandatory": [ "control" ] } },
                    "to": [ { "key_code": "japanese_kana" } ]
                }
            ]
        },
        {
            "description": "Ctrl+L -> 英数",
            "manipulators": [
                {
                    "type": "basic",
                    "from": { "key_code": "l", "modifiers": { "mandatory": [ "control" ] } },
                    "to": [ { "key_code": "japanese_eisuu" } ]
                }
            ]
        },
        {
            "description": "Ctrl+L -> 英数 if japanese mode",
            "manipulators": [
                {
                    "type": "basic",
                    "conditions": [ { "input_sources": [ { "language": "ja" } ], "type": "input_source_if" } ],
                    "from": { "key_code": "l", "modifiers": { "mandatory": [ "control" ] } },
                    "to": [ { "key_code": "japanese_eisuu" } ]
                }
            ]
        },
        {
            "description": "Ctrl+[ -> 英数, ESC",
            "manipulators": [
                {
                    "type": "basic",
                    "from": { "key_code": "open_bracket", "modifiers": { "mandatory": [ "control" ] } },
                    "to": [
                        { "key_code": "japanese_eisuu" },
                        { "key_code": "escape" }
                    ]
                }
            ]
        }
    ]
}
