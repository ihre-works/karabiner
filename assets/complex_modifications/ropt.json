{
    "title": "IME(ROpt+J/L で切り替え、ROpt は英数にマッピング）",
    "rules": [
        {
            "description": "ROpt Only to Escape",
            "manipulators": [
                {
                    "type": "basic",
                    "from": { "key_code": "right_option", "modifiers": { "optional": [ "any" ] } },
                    "parameters": {
                        "basic.to_if_alone_timeout_milliseconds": 2000
                    },
                    "to": [ { "key_code": "right_option", "lazy": true } ],
                    "to_if_alone": [
                        { "key_code": "japanese_eisuu" },
                        { "key_code": "escape" }
                    ]
                }
            ]
        },
        {
            "description": "ROpt+H to DeleteOrBackspace",
            "manipulators": [
                {
                    "type": "basic",
                    "from": { "key_code": "h", "modifiers": { "mandatory": [ "right_option" ] } },
                    "to": [ { "key_code": "delete_or_backspace" } ]
                }
            ]
        },
        {
            "description": "ROpt+H to Control+H",
            "manipulators": [
                {
                    "type": "basic",
                    "from": { "key_code": "h", "modifiers": { "mandatory": [ "right_option" ] } },
                    "to": [ { "key_code": "h", "modifiers": [ "left_control" ] } ]
                }
            ]
        },
        {
            "description": "ROpt+M to ReturnOrEnter",
            "manipulators": [
                {
                    "type": "basic",
                    "from": { "key_code": "m", "modifiers": { "mandatory": [ "right_option" ] } },
                    "to": [ { "key_code": "return_or_enter" } ]
                }
            ]
        },
        {
            "description": "ROpt+J to かな",
            "manipulators": [
                {
                    "type": "basic",
                    "from": { "key_code": "j", "modifiers": { "mandatory": [ "right_option" ] } },
                    "to": [ { "key_code": "japanese_kana" } ]
                }
            ]
        },
        {
            "description": "ROpt+L to 英数",
            "manipulators": [
                {
                    "type": "basic",
                    "from": { "key_code": "l", "modifiers": { "mandatory": [ "right_option" ] } },
                    "to": [ { "key_code": "japanese_eisuu" } ]
                }
            ]
        }
    ]
}
