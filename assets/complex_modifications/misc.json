{
    "title": "Misc",
    "rules": [
        {
            "description": "macSKK for Terminal/iTerm2",
            "manipulators": [
                {
                    "type": "basic",
                    "conditions": [
                        {
                            "bundle_identifiers": [
                                "^com\\.googlecode\\.iterm2",
                                "^com\\.apple\\.Terminal"
                            ],
                            "type": "frontmost_application_if"
                        },
                        {
                            "input_sources": [
                                {
                                    "input_source_id": "^net\\.mtgto\\.inputmethod\\.macSKK\\.(ascii|hiragana|katakana|hankaku|eisu)$"
                                }
                            ],
                            "type": "input_source_if"
                        }
                    ],
                    "from": { "key_code": "j", "modifiers": { "mandatory": [ "left_control" ] } },
                    "to": [ { "key_code": "japanese_kana" } ]
                }
            ]
        },
        {
            "description": "Return を他のキーと同時押しで Fn",
            "manipulators": [
                {
                    "type": "basic",
                    "from": { "key_code": "return_or_enter", "modifiers": { "optional": [ "any" ] } },
                    "to": [ { "key_code": "fn", "lazy": true } ],
                    "to_if_alone": [ { "key_code": "return_or_enter" } ]
                }
            ]
        },
        {
            "description": "Tab を他のキーと同時押しで Fn",
            "manipulators": [
                {
                    "type": "basic",
                    "from": { "key_code": "tab", "modifiers": { "optional": [ "any" ] } },
                    "to": [ { "key_code": "fn", "lazy": true } ],
                    "to_if_alone": [ { "key_code": "tab" } ]
                }
            ]
        },
        {
            "description": "Caps_lock -> Shift+Cmd+Opt",
            "manipulators": [
                {
                    "type": "basic",
                    "from": { "key_code": "caps_lock", "modifiers": { "optional": [ "any" ] } },
                    "to": [ { "key_code": "left_shift", "modifiers": [ "left_command", "left_option" ] } ]
                }
            ]
        },
        {
            "description": "LCmd Only -> 英数,ESC",
            "manipulators": [
                {
                    "type": "basic",
                    "from": { "key_code": "left_command", "modifiers": { "optional": [ "any" ] } },
                    "parameters": { "basic.to_if_alone_timeout_milliseconds": 200 },
                    "to": [ { "key_code": "left_command", "lazy": true } ],
                    "to_if_alone": [ { "key_code": "japanese_eisuu" }, { "key_code": "escape" } ]
                }
            ]
        },
        {
            "description": "RightShift -> Cmd+Opt",
            "manipulators": [
                {
                    "type": "basic",
                    "from": { "key_code": "right_shift", "modifiers": { "optional": [ "any" ] } },
                    "to": [ { "key_code": "left_command", "modifiers": [ "left_option" ] } ]
                }
            ]
        },
        {
            "description": "ESC -> 英数,ESC",
            "manipulators": [
                {
                    "type": "basic",
                    "from": { "key_code": "escape" },
                    "to": [ { "key_code": "japanese_eisuu" }, { "key_code": "escape" } ]
                }
            ]
        }
    ]
}
